const { connect, StringCodec } = require('nats');
let nc, js , sc;

async function initNats(params) {
    if(nc) return {nc , sc, js };
    nc = await connect({ servers: params.servers || 'nats://localhost:4222' });
    sc = StringCodec();
    js = nc.jetstream();
    return {nc , sc, js };
}
async function publish(subject, payload) {
    const { js, sc } = await initNats({});
    return js.publish (subject, sc.encode(JSON.stringify(payload)));
}
module.exports = { initNats, publish };

